{
  "name": "ccalm-rules",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -C web dev",
    "build": "pnpm -C web build",
    "preview": "pnpm -C web preview",
    "lint": "pnpm lint:ox && pnpm lint:eslint",
    "lint:ox": "oxlint -c .oxlintrc.json web/src",
    "lint:ox:fix": "oxlint -c .oxlintrc.json web/src --fix",
    "lint:eslint": "eslint web",
    "lint:eslint:fix": "eslint web --fix",
    "fmt": "oxfmt -c .oxfmtrc.json web",
    "fmt:check": "oxfmt -c .oxfmtrc.json --check web",
    "check": "pnpm fmt:check && pnpm lint"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "typescript-eslint": "^8.59.3"
  }
}
